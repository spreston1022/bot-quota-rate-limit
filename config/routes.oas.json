{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "My Zuplo API"
  },
  "paths": {
    "/path-1": {
      "get": {
        "summary": "Path 1",
        "description": "Rate limited to 10 req/min when the akamai-bot header contains 'intuit'",
        "x-zuplo-route": {
          "handler": {
            "export": "default",
            "module": "$import(./modules/hello-world)"
          },
          "policies": {
            "inbound": ["rate-limit-akamai-bot-intuit"]
          }
        },
        "operationId": "get-path-1",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/path-2": {
      "get": {
        "summary": "Path 2",
        "description": "Monthly quota of 200 requests with consumption logging",
        "x-zuplo-route": {
          "handler": {
            "export": "default",
            "module": "$import(./modules/hello-world)"
          },
          "policies": {
            "inbound": ["quota-path-2", "quota-logger-path-2"]
          }
        },
        "operationId": "get-path-2",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    }
  }
}
